# LangChain AI Project - Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
# Leave blank to use Ollama instead
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Set a specific OpenAI model (default: gpt-3.5-turbo)
# OPENAI_MODEL=gpt-4

# Ollama Configuration
# Ensure Ollama is running locally (default port: 11434)
# Models available: gemma3:270m, llama2, mistral, neural-chat, etc.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:270m

# Optional: LLM Temperature (0-2)
# 0 = deterministic, focused responses
# 0.5-0.7 = balanced
# 1.0+ = creative, random responses
# LLM_TEMPERATURE=0

# Optional: Logging Configuration
# DEBUG=false
# LOG_LEVEL=INFO
